{
    "layer": "top",
    "position": "top",
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock"],
    "modules-right": [
        "network",
        "custom/brightness",
        "pulseaudio",
        "temperature",
        "cpu",
        "memory",
        "custom/notification"
    ],
    "sway/workspaces": {
        "disable-scroll": false,
        "format": "{name}"
    },
    "custom/brightness": {
        "tooltip": false,
        "format": "BRI {}",
        "exec": "ddcutil getvcp 10 --brief 2>/dev/null | awk '{print $4}'",
        "interval": 5,
        "signal": 1,
        "on-scroll-up": "ddcutil setvcp 10 + 10 && pkill -SIGRTMIN+1 waybar",
        "on-scroll-down": "ddcutil setvcp 10 - 10 && pkill -SIGRTMIN+1 waybar"
    },
    "pulseaudio": {
        "format": "VOL {volume}",
        "format-bluetooth": "BT {volume}",
        "format-muted": "MUTE",
        "format-bluetooth-muted": "BT MUTE",
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "NET {essid}",
        "format-ethernet": "NET ETH",
        "format-disconnected": "NET --",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}"
    },
    "temperature": {
        "tooltip": false,
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "format": "TMP {temperatureC}C",
        "critical-threshold": 85,
        "interval": 1
    },
    "cpu": {
        "tooltip": false,
        "format": "CPU {usage}",
        "interval": 1
    },
    "memory": {
        "tooltip": false,
        "format": "MEM {used:0.1f}G",
        "interval": 1
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "NOTIF *",
            "none": "NOTIF",
            "dnd-notification": "DND *",
            "dnd-none": "DND"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "clock": {
        "tooltip": false,
        "format": "{:%a %m/%d %H:%M}",
        "interval": 1
    }
}
