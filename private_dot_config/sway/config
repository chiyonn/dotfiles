### common valiables
set $mod Mod1
set $sub Mod4

set $left h
set $down j
set $up k
set $right l

# apps
set $term foot
set $filer nautilus
set $browser firefox
set $menu wofi --show drun

# short handlers
set $scratchpad_call ~/.config/sway/scripts/scratchpad_firefox.sh

### window control
floating_modifier $mod normal

# gaps
default_border pixel 3
gaps inner 0
gaps outer 0

# colors
#                           border   bg       text     indi     childborder
client.focused          #ffffff  #ffffff  #000000  #ff3333  #ffffff
client.focused_inactive #333333  #000000  #ffffff  #333333  #333333
client.unfocused        #333333  #000000  #ffffff  #333333  #333333
client.urgent           #ff3333  #ff3333  #000000  #ff3333  #ff3333


### idle control
exec swayidle -w \
    timeout 1800 'swaylock -f' \
    timeout 3600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f'

bindsym $mod+Backspace exec swaylock -f
bindsym $mod+Shift+BackSpace exec systemctl suspend



for_window [app_id="blueman-manager"] floating enable, border pixel 2
for_window [app_id="org.pulseaudio.pavucontrol"] floating enable, border pixel 2


include /etc/sway/config.d/*
include $HOME/.config/sway/config.d/*
