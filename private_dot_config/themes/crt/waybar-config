{
    "layer": "top",
    "position": "bottom",
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock"],
    "modules-right": [
        "network",
        "pulseaudio",
        "temperature",
        "cpu",
        "memory",
        "custom/notification"
    ],
    "sway/workspaces": {
        "disable-scroll": false,
        "format": "[{name}]"
    },
    "pulseaudio": {
        "format": "vol:{volume}",
        "format-bluetooth": "bt:{volume}",
        "format-muted": "vol:--",
        "format-bluetooth-muted": "bt:--",
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "net:{essid}",
        "format-ethernet": "net:eth0",
        "format-disconnected": "net:none",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}"
    },
    "temperature": {
        "tooltip": false,
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "format": "tmp:{temperatureC}c",
        "critical-threshold": 85,
        "interval": 1
    },
    "cpu": {
        "tooltip": false,
        "format": "cpu:{usage}%",
        "interval": 1
    },
    "memory": {
        "tooltip": false,
        "format": "mem:{used:0.1f}g",
        "interval": 1
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "msg:*",
            "none": "msg:0",
            "dnd-notification": "dnd:*",
            "dnd-none": "dnd"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "clock": {
        "tooltip": false,
        "format": "{:%H:%M:%S}",
        "interval": 1
    }
}
